service firebase.storage {
  match /b/{bucket}/o {
    // Allow public read of publicly-shared assets if needed (adjust if you prefer private)
    match /public/{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }

    // User profile photos are stored under user_photos/{uid}/...
    match /user_photos/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
